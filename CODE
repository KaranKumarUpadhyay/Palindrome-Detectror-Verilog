module palindrome_detector (
    input clk,
    input reset,
    input x,        
    output reg y    
);

reg [1:0] state, next_state;
reg [3:0] shift_reg;

parameter sa=2'b00, sb=2'b01, sc=2'b10, sd=2'b11;

// State register
always @(posedge clk or posedge reset)
begin
    if (reset)
        state <= sa;
    else
        state <= next_state;
end

// Shift register to store last 4 bits
always @(posedge clk or posedge reset)
begin
    if (reset)
        shift_reg <= 4'b0000;
    else
        shift_reg <= {shift_reg[2:0], x};
end

// Simple state progression (just to match FSM style)
always @(*)
begin
    case(state)
    sa: next_state = sb;
    sb: next_state = sc;
    sc: next_state = sd;
    sd: next_state = sd;
    endcase
end

// Output logic: check palindrome
always @(*)
begin
    if (state==sd && (shift_reg[3]==shift_reg[0]) && (shift_reg[2]==shift_reg[1]))
        y = 1;
    else
        y = 0;
end

endmodule
